<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ريلز الشيخ - رحلة إلى الله</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Kufi+Arabic:wght@300;400;600;700;800;900&family=Amiri:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --sunset-deep: #1a0a2e;
    --sunset-purple: #2d1b4e;
    --sunset-warm: #8b2f5f;
    --sunset-orange: #d4622a;
    --sunset-gold: #e8a838;
    --sunset-light: #f5c96a;
    --sunset-cream: #fdf0d5;
    --sunset-white: #fff8ee;
    --sunset-glow: #ff6b3520;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: 'Noto Kufi Arabic', sans-serif;
    background: var(--sunset-deep);
    color: var(--sunset-cream);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* === خلفية متحركة === */
  .bg-atmosphere {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .bg-atmosphere::before {
    content: '';
    position: absolute;
    top: -30%;
    right: -20%;
    width: 70vw;
    height: 70vw;
    background: radial-gradient(circle, rgba(212, 98, 42, 0.15) 0%, transparent 70%);
    animation: floatBlob1 12s ease-in-out infinite;
  }

  .bg-atmosphere::after {
    content: '';
    position: absolute;
    bottom: -20%;
    left: -15%;
    width: 60vw;
    height: 60vw;
    background: radial-gradient(circle, rgba(139, 47, 95, 0.12) 0%, transparent 70%);
    animation: floatBlob2 15s ease-in-out infinite;
  }

  @keyframes floatBlob1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-5%, 8%) scale(1.1); }
  }

  @keyframes floatBlob2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(6%, -6%) scale(1.15); }
  }

  .stars {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .star {
    position: absolute;
    width: 2px;
    height: 2px;
    background: var(--sunset-light);
    border-radius: 50%;
    animation: twinkle var(--dur) ease-in-out infinite;
    opacity: 0;
  }

  @keyframes twinkle {
    0%, 100% { opacity: 0; }
    50% { opacity: var(--max-o, 0.6); }
  }

  /* === الحاوية الرئيسية === */
  .slide-container {
    position: relative;
    z-index: 1;
    max-width: 960px;
    margin: 0 auto;
    padding: 40px 20px 60px;
  }

  /* === الهيدر مع اللوجو === */
  .header {
    text-align: center;
    margin-bottom: 50px;
    animation: fadeInDown 1s ease-out;
  }

  @keyframes fadeInDown {
    from { opacity: 0; transform: translateY(-30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .logo-wrapper {
    position: relative;
    display: inline-block;
    margin-bottom: 28px;
  }

  .logo-wrapper::before {
    content: '';
    position: absolute;
    inset: -12px;
    border-radius: 50%;
    background: conic-gradient(from 0deg, var(--sunset-orange), var(--sunset-gold), var(--sunset-warm), var(--sunset-orange));
    animation: logoGlow 4s linear infinite;
    opacity: 0.6;
    filter: blur(6px);
  }

  @keyframes logoGlow {
    to { transform: rotate(360deg); }
  }

  .logo-img {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    object-fit: cover;
    position: relative;
    z-index: 1;
    border: 3px solid var(--sunset-gold);
    box-shadow: 0 0 40px rgba(232, 168, 56, 0.3), 0 8px 32px rgba(0,0,0,0.4);
  }

  .header-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 900;
    background: linear-gradient(135deg, var(--sunset-gold), var(--sunset-light), var(--sunset-orange));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 8px;
    letter-spacing: 1px;
  }

  .header-sub {
    font-family: 'Amiri', serif;
    font-size: 1.15rem;
    color: rgba(253, 240, 213, 0.6);
    font-weight: 400;
  }

  .divider {
    width: 120px;
    height: 2px;
    margin: 20px auto 0;
    background: linear-gradient(90deg, transparent, var(--sunset-gold), transparent);
    border-radius: 2px;
  }

  /* === كروت الريلز === */
  .reels-grid {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .reel-card {
    position: relative;
    background: linear-gradient(145deg, rgba(45, 27, 78, 0.6), rgba(26, 10, 46, 0.8));
    border: 1px solid rgba(232, 168, 56, 0.15);
    border-radius: 20px;
    padding: 32px 28px;
    overflow: hidden;
    backdrop-filter: blur(10px);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
    transform: translateY(40px);
  }

  .reel-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .reel-card:hover {
    border-color: rgba(232, 168, 56, 0.35);
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.3), 0 0 40px rgba(232, 168, 56, 0.08);
  }

  .reel-card::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle at top right, rgba(212, 98, 42, 0.08), transparent 70%);
    pointer-events: none;
  }

  .reel-number {
    position: absolute;
    top: 16px;
    left: 20px;
    font-size: 3.5rem;
    font-weight: 900;
    color: rgba(232, 168, 56, 0.07);
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--sunset-gold);
    margin-bottom: 16px;
    padding: 4px 14px;
    background: rgba(232, 168, 56, 0.08);
    border-radius: 20px;
    border: 1px solid rgba(232, 168, 56, 0.15);
  }

  .section-label .dot {
    width: 6px;
    height: 6px;
    background: var(--sunset-orange);
    border-radius: 50%;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.7); }
  }

  .hook-text {
    font-size: clamp(1.1rem, 2.5vw, 1.35rem);
    font-weight: 700;
    color: var(--sunset-white);
    line-height: 1.8;
    margin-bottom: 18px;
    position: relative;
    padding-right: 16px;
    border-right: 3px solid var(--sunset-orange);
  }

  .content-text {
    font-size: 0.95rem;
    color: rgba(253, 240, 213, 0.7);
    line-height: 1.9;
    margin-bottom: 18px;
    padding-right: 16px;
  }

  .content-text strong {
    color: var(--sunset-light);
    font-weight: 600;
  }

  .cta-box {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: linear-gradient(135deg, rgba(232, 168, 56, 0.12), rgba(212, 98, 42, 0.12));
    border: 1px solid rgba(232, 168, 56, 0.25);
    border-radius: 12px;
    padding: 12px 22px;
    font-size: 1rem;
    font-weight: 700;
    color: var(--sunset-gold);
    transition: all 0.3s ease;
  }

  .reel-card:hover .cta-box {
    background: linear-gradient(135deg, rgba(232, 168, 56, 0.18), rgba(212, 98, 42, 0.18));
    border-color: rgba(232, 168, 56, 0.4);
    box-shadow: 0 4px 20px rgba(232, 168, 56, 0.1);
  }

  .cta-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  /* === تدرجات مختلفة لكل كارت === */
  .reel-card:nth-child(1) { border-right: 3px solid var(--sunset-gold); }
  .reel-card:nth-child(2) { border-right: 3px solid var(--sunset-orange); }
  .reel-card:nth-child(3) { border-right: 3px solid var(--sunset-warm); }
  .reel-card:nth-child(4) { border-right: 3px solid var(--sunset-purple); border-right-color: #a855f7; }

  .reel-card:nth-child(1) .hook-text { border-right-color: var(--sunset-gold); }
  .reel-card:nth-child(2) .hook-text { border-right-color: var(--sunset-orange); }
  .reel-card:nth-child(3) .hook-text { border-right-color: var(--sunset-warm); }
  .reel-card:nth-child(4) .hook-text { border-right-color: #a855f7; }

  /* === الفوتر === */
  .footer {
    text-align: center;
    margin-top: 50px;
    padding-top: 30px;
    border-top: 1px solid rgba(232, 168, 56, 0.1);
    animation: fadeIn 1s ease-out 1.5s both;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .footer-logo-small {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(232, 168, 56, 0.3);
    margin-bottom: 12px;
  }

  .footer-text {
    font-family: 'Amiri', serif;
    font-size: 0.95rem;
    color: rgba(253, 240, 213, 0.35);
  }

  /* === الريسبونسف === */
  @media (max-width: 640px) {
    .slide-container { padding: 24px 14px 40px; }
    .logo-img { width: 120px; height: 120px; }
    .reel-card { padding: 24px 18px; border-radius: 16px; }
    .reel-number { font-size: 2.5rem; top: 12px; left: 14px; }
    .hook-text { font-size: 1.05rem; padding-right: 12px; }
    .content-text { font-size: 0.88rem; padding-right: 12px; }
    .cta-box { font-size: 0.9rem; padding: 10px 16px; }
  }

  /* === prefers-reduced-motion === */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
</head>
<body>

<!-- خلفية النجوم -->
<div class="stars" id="stars" aria-hidden="true"></div>
<!-- خلفية التوهجات -->
<div class="bg-atmosphere" aria-hidden="true"></div>

<main class="slide-container">
  <!-- === الهيدر === -->
  <header class="header">
    <div class="logo-wrapper">
      <img 
        src="https://z-cdn-media.chatglm.cn/files/56e4f763-4575-4174-be4b-e10ab015ee5c.png?auth_key=1882328366-2270db6f9ce44fe69ad57bb0a39e6a85-0-509a054ebd565ae3db557ce6d9240eb0" 
        alt="شعار رحلة إلى الله" 
        class="logo-img"
      />
    </div>
    <h1 class="header-title">ريلز الشيخ</h1>
    <p class="header-sub">أفكار محتوى لسلسلة رحلة إلى الله</p>
    <div class="divider"></div>
  </header>

  <!-- === كروت الريلز === -->
  <section class="reels-grid" aria-label="كروت الريلز">

    <!-- ريلز 1 -->
    <article class="reel-card" data-delay="0">
      <span class="reel-number">01</span>
      <div class="section-label"><span class="dot"></span>الهوك</div>
      <p class="hook-text">"إحنا حافظين أسامي ربنا.. بسهل فعًلا عارفينه؟"</p>
      <p class="content-text"><strong>المحتوى:</strong> الشيخ يتحدث عن الفرق بين المعلومة النظرية والعيش مع الله.</p>
      <div class="cta-box">
        <svg class="cta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
        لو عايز تبدأ الرحلة بجد، استنى اللي جاي
      </div>
    </article>

    <!-- ريلز 2 -->
    <article class="reel-card" data-delay="150">
      <span class="reel-number">02</span>
      <div class="section-label"><span class="dot"></span>الهوك</div>
      <p class="hook-text">"ساعات المنع بيكون هو قمة العطاء.. بس إحنا اللي مستعجلين."</p>
      <p class="content-text"><strong>المحتوى:</strong> قصة شخصية قصيرة للشيخ عن موقف ظاهره شر وباطنه لطف.</p>
      <div class="cta-box">
        <svg class="cta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
        قول "يا لطيف" من قلبك النهاردة
      </div>
    </article>

    <!-- ريلز 3 -->
    <article class="reel-card" data-delay="300">
      <span class="reel-number">03</span>
      <div class="section-label"><span class="dot"></span>الهوك</div>
      <p class="hook-text">"بتصلي وبتحس إنك بتأدي واجب؟ المشكلة مش في الصلاة، المشكلة في 'مين' اللي بتصلي له."</p>
      <p class="content-text"><strong>المحتوى:</strong> التركيز على أن معرفة الله هي روح العبادة.</p>
      <div class="cta-box">
        <svg class="cta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
        جاهز تشحن روحك؟
      </div>
    </article>

    <!-- ريلز 4 -->
    <article class="reel-card" data-delay="450">
      <span class="reel-number">04</span>
      <div class="section-label"><span class="dot"></span>الهوك</div>
      <p class="hook-text">"لو فاكر إننا هنحفظ معاني أسامي.. فإنت غلطان. إحنا هنعيشها."</p>
      <p class="content-text"><strong>المحتوى:</strong> التركيز على الجانب العملي والواجبات اليومية في الدورة.</p>
      <div class="cta-box">
        <svg class="cta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
        خليك معانا
      </div>
    </article>

  </section>

  <!-- === الفوتر === -->
  <footer class="footer">
    <img 
      src="https://z-cdn-media.chatglm.cn/files/56e4f763-4575-4174-be4b-e10ab015ee5c.png?auth_key=1882328366-2270db6f9ce44fe69ad57bb0a39e6a85-0-509a054ebd565ae3db557ce6d9240eb0" 
      alt="شعار" 
      class="footer-logo-small"
    />
    <p class="footer-text">رحلة إلى الله</p>
  </footer>
</main>

<script>
  // === إنشاء النجوم ===
  (function createStars() {
    const container = document.getElementById('stars');
    const count = 60;
    for (let i = 0; i < count; i++) {
      const star = document.createElement('div');
      star.classList.add('star');
      star.style.left = Math.random() * 100 + '%';
      star.style.top = Math.random() * 100 + '%';
      star.style.setProperty('--dur', (3 + Math.random() * 5) + 's');
      star.style.setProperty('--max-o', (0.3 + Math.random() * 0.5).toFixed(2));
      star.style.animationDelay = (Math.random() * 5) + 's';
      const size = 1 + Math.random() * 2;
      star.style.width = size + 'px';
      star.style.height = size + 'px';
      container.appendChild(star);
    }
  })();

  // === ظهور الكروت عند التمرير ===
  (function revealCards() {
    const cards = document.querySelectorAll('.reel-card');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const delay = parseInt(entry.target.dataset.delay) || 0;
          setTimeout(() => {
            entry.target.classList.add('visible');
          }, delay);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });

    cards.forEach(card => observer.observe(card));
  })();
</script>
</body>
</html>
